<Window x:Class="AC10.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Endüstriyel Dozaj" Height="900" Width="1600"
        Background="#181B21" WindowStartupLocation="CenterScreen" WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="ScadaCard" TargetType="Border">
            <Setter Property="Background" Value="#21252D"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#000000" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#313743"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 🔥 DÜZELTME: Hatalı oranlara sebep olan ColumnDefinitions kaldırıldı -->
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition/>
            <RowDefinition Height="134.04"/>
            <!-- Alt panelin boyutu tam sabitlendi -->
        </Grid.RowDefinitions>

        <!-- HEADER BAR -->
        <Border Grid.Row="0" Background="#21252D" BorderBrush="#181B21" BorderThickness="0,0,0,2">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ELİMKO AC-10" Foreground="#61AFEF" FontSize="20" FontWeight="Black" Margin="0,0,30,0" VerticalAlignment="Center"/>

                    <TextBlock Text="Port:" Foreground="#ABB2BF" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox x:Name="txtPort" Text="COM2" Width="55" Background="#181B21" Foreground="White" BorderThickness="1" BorderBrush="#313743" TextAlignment="Center" Padding="2"/>

                    <TextBlock Text="Baud:" Foreground="#ABB2BF" VerticalAlignment="Center" Margin="15,0,5,0"/>
                    <TextBox x:Name="txtBaudRate" Text="9600" Width="55" Background="#181B21" Foreground="White" BorderThickness="1" BorderBrush="#313743" TextAlignment="Center" Padding="2"/>

                    <TextBlock Text="ID:" Foreground="#ABB2BF" VerticalAlignment="Center" Margin="15,0,5,0"/>
                    <TextBox x:Name="txtSlaveId" Text="1" Width="35" Background="#181B21" Foreground="White" BorderThickness="1" BorderBrush="#313743" TextAlignment="Center" Padding="2"/>

                    <Button x:Name="btnConnect" Content="Sisteme Bağlan" Background="#98C379" Foreground="#181B21" FontWeight="Bold" Margin="15,0,0,0" Padding="15,5" Click="btnConnect_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnReports" Content="📊 Alarmlar ve Raporlar" Background="#C678DD" Foreground="White" Margin="0,0,20,0" Padding="10,5" Click="btnReports_Click"/>
                    <Ellipse x:Name="lblHeartbeat" Width="14" Height="14" Fill="#E06C75" Margin="0,0,8,0"/>
                    <TextBlock Text="Haberleşme Durumu" Foreground="#ABB2BF" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="2.6*"/>
                    <ColumnDefinition Width="1.45*"/>
                    <ColumnDefinition Width="1.45*"/>
                </Grid.ColumnDefinitions>

                <!-- COLUMN 1: LIVE DATA -->
                <Border Grid.Column="0" Style="{StaticResource ScadaCard}">
                    <StackPanel>
                        <TextBlock Text="📊 CANLI VERİLER" Foreground="#E5C07B" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Debi Seti (Reg 1)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblSetPoint" Text="0 ton/sa" Foreground="#E5C07B" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Ortalama Debi (Reg 2)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblAverageFlow" Text="0.0 ton/sa" Foreground="#56B6C2" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Anlık Debi (Reg 3)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblFlowRate" Text="0.0 ton/sa" Foreground="#61AFEF" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Ağırlık (Reg 4)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblCurrentWeight" Text="0.00 kg" Foreground="#98C379" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Hız (Reg 5)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblBeltSpeed" Text="0" Foreground="#C678DD" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Kontrol Çıkışı (Reg 6)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblControlOutput" Text="0" Foreground="#D19A66" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Toplayıcı 1 (Reg 7-8)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblTotalWeight1" Text="0 ton" Foreground="#98C379" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Toplayıcı 2 (Reg 9-10)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblTotalWeight2" Text="0 ton" Foreground="#61AFEF" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Ağırlık Seti (Reg 11)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblWeightSetRead" Text="0 ton" Foreground="#E5C07B" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Geçen Mal Toplamı (Reg 12)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblTotalPassed" Text="0 ton" Foreground="#C678DD" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Ön Besleyici (Reg 13)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblPreFeederOutput" Text="0" Foreground="#E06C75" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,0">
                            <TextBlock Text="Noktanın Yeri (Reg 17)" Foreground="#ABB2BF" FontSize="11"/>
                            <TextBlock x:Name="lblDecimalPoint" Text="0" Foreground="#ABB2BF" FontSize="22" FontWeight="Bold" FontFamily="Consolas"/>
                        </StackPanel>

                        <Separator Background="#313743" Margin="0,5,0,10"/>

                    </StackPanel>
                </Border>

                <!-- COLUMN 2: I/O (INPUT, OUTPUT, STATUS) -->
                <Border Grid.Column="1" Style="{StaticResource ScadaCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1.3*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="🚥 I-O-S GÖSTERGE" Foreground="#E5C07B" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="GİRİŞLER (InV)" Foreground="#61AFEF" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>
                                <UniformGrid Grid.Row="1" Columns="1" x:Name="gridInputs" VerticalAlignment="Stretch"/>
                            </Grid>

                            <Grid Grid.Column="1" Margin="8,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="ÇIKIŞLAR (InO)" Foreground="#C678DD" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>
                                <UniformGrid Grid.Row="1" Columns="1" x:Name="gridOutputs" VerticalAlignment="Stretch"/>
                            </Grid>
                        </Grid>

                        <Separator Grid.Row="2" Background="#313743" Margin="0,15,0,15"/>

                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="SİSTEM DURUM (InS)" Foreground="#98C379" FontWeight="Bold" FontSize="15" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <UniformGrid Grid.Row="1" Columns="2" x:Name="gridStatus" VerticalAlignment="Stretch"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- COLUMN 3: SETTINGS & BUNKER -->
                <Border Grid.Column="2" Style="{StaticResource ScadaCard}">
                    <StackPanel>
                        <TextBlock Text="📐 PARAMETRE &amp; BUNKER" Foreground="#E5C07B" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="Debi Seti Gir (Reg 30):" Foreground="#ABB2BF" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtTargetDose" Text="0" Background="#181B21" Foreground="White" FontSize="14" Padding="4" BorderThickness="1" BorderBrush="#313743" Margin="0,0,0,8"/>

                        <TextBlock Text="Ağırlık Set Değeri (Reg 33):" Foreground="#ABB2BF" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtWeightSet" Text="0" Background="#181B21" Foreground="White" FontSize="14" Padding="4" BorderThickness="1" BorderBrush="#313743" Margin="0,0,0,8"/>

                        <TextBlock x:Name="lblBunkerSetTitle" Text="Bunker Set Yaz (Reg 34):" Foreground="#5C6370" FontSize="11" Margin="0,0,0,2"/>
                        <TextBox x:Name="txtBunkerWeightSet" Text="0" Background="#313743" Foreground="#ABB2BF" FontSize="14" Padding="4" BorderThickness="1" BorderBrush="#313743" Margin="0,0,0,10" IsEnabled="False"/>

                        <Button x:Name="btnSendSettings" Content="Ayarları Cihaza Gönder" Background="#56B6C2" Foreground="#181B21" Margin="0,0,0,10" Click="btnSendSettings_Click"/>

                        <Separator Background="#313743" Margin="0,0,0,10"/>

                        <CheckBox x:Name="chkBunkerEnabled" Content="Bunker Sistemi Mevcut" Foreground="White" FontWeight="Bold" FontSize="12" Margin="0,0,0,8" Checked="chkBunkerEnabled_CheckedChanged" Unchecked="chkBunkerEnabled_CheckedChanged"/>

                        <Border x:Name="pnlBunker" Background="#181B21" CornerRadius="4" Padding="8" IsEnabled="False">
                            <StackPanel>
                                <UniformGrid Columns="2" Margin="0,0,0,5">
                                    <StackPanel Margin="0,0,3,5">
                                        <TextBlock Text="Bunker Ağırlık (Reg 18)" Foreground="#ABB2BF" FontSize="10"/>
                                        <TextBlock x:Name="lblBunkerWeight" Text="0 ton" Foreground="#E5C07B" FontSize="14" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,3,5">
                                        <TextBlock Text="Bunker Ağırlık Set (Reg 19)" Foreground="#ABB2BF" FontSize="10"/>
                                        <TextBlock x:Name="lblBunkerWeightSetRead" Text="0 ton" Foreground="#E5C07B" FontSize="14" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,3,5">
                                        <TextBlock Text="Bunker Ağırlık Çıkış (Reg 20)" Foreground="#ABB2BF" FontSize="10"/>
                                        <TextBlock x:Name="lblBunkerControlOutput" Text="0" Foreground="#D19A66" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,3,5">
                                        <TextBlock Text="Oto Boşalan Ağırlık (Reg 22)" Foreground="#ABB2BF" FontSize="10"/>
                                        <TextBlock x:Name="lblBunkerDischargedWeight" Text="0 kg" Foreground="#C678DD" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,3,5">
                                        <TextBlock Text="Oto Bandın Tarttığı (Reg 23)" Foreground="#ABB2BF" FontSize="10"/>
                                        <TextBlock x:Name="lblBeltWeighedWeight" Text="0 kg" Foreground="#56B6C2" FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                </UniformGrid>

                                <TextBlock Text="Bunker Durum (Status)" Foreground="#98C379" FontWeight="Bold" FontSize="11" Margin="0,2,0,5"/>
                                <UniformGrid Columns="1" x:Name="gridBunkerStatus"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- COLUMN 4: CONTROL BUTTONS -->
                <Border Grid.Column="3" Style="{StaticResource ScadaCard}">
                    <StackPanel>
                        <TextBlock Text="🕹️ SİSTEM KONTROL" Foreground="#E5C07B" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="KOMUT 1 (Reg 31)" Foreground="#ABB2BF" FontWeight="Bold" FontSize="11" Margin="0,0,0,3"/>
                        <UniformGrid Columns="2" Rows="4" Margin="0,0,0,10">
                            <Button x:Name="btnSystemRun" Content="ÇALIŞ" Click="btnSystemRun_Click"/>
                            <Button x:Name="btnPreSystemRun" Content="ÖN SİSTEM" Click="btnPreSystemRun_Click"/>
                            <Button x:Name="btnMotorRun" Content="MOTOR ÇALIŞ." Click="btnMotorRun_Click"/>
                            <Button x:Name="btnMotorFault" Content="MOTOR ARIZA" Click="btnMotorFault_Click"/>
                            <Button x:Name="btnPreFeederRun" Content="ÖN BES. ÇALIŞ." Click="btnPreFeederRun_Click"/>
                            <Button x:Name="btnPreFeederFault" Content="ÖN BES. ARIZA" Click="btnPreFeederFault_Click"/>
                            <Button x:Name="btnRemoteOperation" Content="UZAK" Click="btnRemoteOperation_Click"/>
                            <Button x:Name="btnLocalOperation" Content="YAKIN" Click="btnLocalOperation_Click"/>
                        </UniformGrid>

                        <TextBlock Text="KOMUT 2 (Reg 32)" Foreground="#ABB2BF" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                        <UniformGrid Columns="2" Rows="4">
                            <Button x:Name="btnResetTotalizer" Content="TOPLAYICI SİL" Background="#D19A66" Foreground="#181B21" Click="btnResetTotalizer_Click"/>
                            <Button x:Name="btnResetFaults" Content="ARIZA SİL" Background="#E06C75" Click="btnResetFaults_Click"/>
                            <Button Content="---" IsEnabled="False"/>
                            <Button Content="---" IsEnabled="False"/>
                            <Button x:Name="btnStartCalibration" Content="KALİB. BAŞLA" Click="btnStartCalibration_Click"/>
                            <Button x:Name="btnAcceptCalibration" Content="KALİB. KABUL" Click="btnAcceptCalibration_Click"/>
                            <Button x:Name="btnRejectCalibration" Content="KALİB. RED" Click="btnRejectCalibration_Click"/>
                            <Button x:Name="btnStopFilling" Content="DOLUM DURDUR." Click="btnStopFilling_Click"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- FOOTER: LOGS -->
        <!-- 🔥 DÜZELTME: İçerideki hatalı oranlamalar silinerek ListBox ekranın alt sınırına kadar net bir şekilde esnetildi -->
        <Border Grid.Row="2" Style="{StaticResource ScadaCard}" Margin="5,10,5,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="811*"/>
                    <ColumnDefinition Width="759*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <!-- Bu yıldız sayesinde ListBox kalan tüm boşluğu kaplar -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📝 CANLI OLAY LOGLARI" Foreground="#E5C07B" FontSize="13" FontWeight="Bold" Margin="0,0,0,8" Grid.ColumnSpan="2"/>

                <ListBox x:Name="lstLogs" Background="#181B21" Foreground="#ABB2BF" BorderThickness="1" BorderBrush="#313743" FontFamily="Consolas" Height="115" VerticalAlignment="Top" Margin="0,10,0,0" Grid.Row="1" Grid.ColumnSpan="2"/>
            </Grid>
        </Border>

    </Grid>
</Window>
